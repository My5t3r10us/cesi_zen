{
  "expo": {
    "name": "CESIZen",
    "slug": "cesizen",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#FAFAF5"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.cesizen.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FAFAF5"
      },
      "package": "com.cesizen.app"
    },
    "scheme": "cesizen",
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
