{
  "name": "cesizen",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "type-check": "tsc --noEmit",
    "check": "npm run lint && npm run type-check",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx lib/db/seed.ts",
    "db:setup": "npm run db:generate && npm run db:migrate && npm run db:seed",
    "db:reset": "psql $DATABASE_URL -f reset-db.sql",
    "db:check-admin": "tsx scripts/check-admin.ts",
    "db:reset-admin": "tsx scripts/reset-admin.ts",
    "start:prod": "drizzle-kit migrate && npm run db:seed && next start"
  },
