# =============================================================
#  Template — Variables d'environnement pour les tests
#  Copier ce fichier en .env.test et adapter si besoin.
#  Ce fichier .example EST versionné (aucune vraie valeur secrète).
# =============================================================

NODE_ENV=test

# ── Base de données ───────────────────────────────────────────
# Démarrer avec : docker compose up -d
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cesizen_test

# ── JWT ───────────────────────────────────────────────────────
# Minimum 32 caractères — valeur non-secrète pour les tests
JWT_SECRET=test-secret-key-for-testing-only-32chars

# ── Chiffrement AES-256 ───────────────────────────────────────
# Exactement 64 caractères hexadécimaux (= 32 octets)
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
